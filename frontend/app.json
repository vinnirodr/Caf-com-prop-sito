{
  "expo": {
    "name": "Café com Propósito",
    "slug": "cafe-com-proposito",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cafecomproposito",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.cafecomproposito.app"
    },
    "android": {
      "package": "com.cafecomproposito.app",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#3A2D22",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O Café com Propósito usa sua localização apenas para mostrar o clima do dia na tela inicial."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#5B4636",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76,
            "backgroundColor": "#5B4636"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/splash-icon.png",
          "color": "#5B4636",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0c243100-0b25-46cf-9d45-04bebe3bf6cb"
      }
    },
    "owner": "vinigreg"
  }
}
