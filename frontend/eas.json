{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://cafe-com-proposito-api.onrender.com",
        "EXPO_PUBLIC_REVENUECAT_ANDROID_KEY": ""
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://cafe-com-proposito-api.onrender.com",
        "EXPO_PUBLIC_REVENUECAT_ANDROID_KEY": ""
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://cafe-com-proposito-api.onrender.com",
        "EXPO_PUBLIC_REVENUECAT_ANDROID_KEY": ""
      }
    }
  },
  "submit": {
    "production": {}
  }
}
