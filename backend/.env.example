# Copie para .env e ajuste. Nunca versione o .env real.
SECRET_KEY=troque-por-uma-chave-secreta-longa
DEBUG=True
ALLOWED_HOSTS=*
# Em produção (ex.: Render), defina a URL do Postgres:
# DATABASE_URL=postgres://usuario:senha@host:5432/banco

# Mídia em nuvem (Cloudflare R2) — defina TODAS para ativar; senão usa disco local.
# R2_BUCKET=cafe-com-proposito-media
# R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_PUBLIC_DOMAIN=pub-xxxx.r2.dev   # URL pública do bucket (r2.dev ou domínio próprio)
